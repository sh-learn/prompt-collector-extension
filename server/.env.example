PORT=8787

# api：relay 直接调飞书 OpenAPI，需要 LARK_APP_ID / LARK_APP_SECRET。
# lark-cli：relay 调用本机 lark-cli，复用本机 lark-cli 配置和登录态。
STORAGE_BACKEND=lark-cli
LARK_CLI_BIN=lark-cli
# 可选：user 复用用户 OAuth；bot 复用应用身份。留空则使用 lark-cli 默认身份。
LARK_CLI_AS=user

LARK_OPENAPI_BASE=https://open.feishu.cn
LARK_APP_ID=cli_xxx
LARK_APP_SECRET=xxx

# 二选一：如果填 WIKI_TOKEN，服务会自动解析到真实 Base token。
LARK_BASE_TOKEN=
LARK_WIKI_TOKEN=

LARK_TABLE_ID=tblxxxx

# 字段名要和飞书多维表格完全一致；不需要的字段可以留空。
FIELD_TITLE=标题
FIELD_PROMPT=Prompt
FIELD_SOURCE_URL=来源链接
FIELD_PAGE_TITLE=页面标题
FIELD_AUTHOR=作者
FIELD_IMAGES=图片
FIELD_CAPTURED_AT=采集时间
FIELD_RAW_JSON=原始数据
